{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/favicon.svg", "destination": "/assets/favicon.svg" },
    { "source": "/favicon-32.png", "destination": "/assets/favicon-32.png" },
    { "source": "/apple-touch-icon.png", "destination": "/assets/apple-touch-icon.png" },
    { "source": "/manifest.webmanifest", "destination": "/assets/manifest.webmanifest" },
    { "source": "/robots.txt", "destination": "/assets/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/assets/sitemap.xml" },
    { "source": "/og-image.jpg", "destination": "/assets/og-image.jpg" },
    { "source": "/logo.png", "destination": "/assets/logo.png" },
    { "source": "/legal/aviso-legal", "destination": "/legal/aviso-legal.html" },
    { "source": "/legal/privacidad", "destination": "/legal/privacidad.html" },
    { "source": "/legal/cookies", "destination": "/legal/cookies.html" },
    { "source": "/legal/terminos", "destination": "/legal/terminos.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(self), camera=(), microphone=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://maps.googleapis.com https://maps.gstatic.com https://plausible.io https://vercel.live https://*.vercel.live; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://vercel.live; font-src 'self' https://fonts.gstatic.com https://vercel.live data:; img-src 'self' data: https: blob:; connect-src 'self' https://maps.googleapis.com https://places.googleapis.com https://*.googleapis.com https://plausible.io https://vercel.live https://*.vercel.live wss://*.vercel.live; frame-src 'self' https://vercel.live; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/admin(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)\\.(svg|png|jpg|jpeg|webp|avif|ico|woff2?)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
