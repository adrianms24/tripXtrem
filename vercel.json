{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/favicon.svg", "destination": "/assets/favicon.svg" },
    { "source": "/favicon-32.png", "destination": "/assets/favicon-32.png" },
    { "source": "/apple-touch-icon.png", "destination": "/assets/apple-touch-icon.png" },
    { "source": "/manifest.webmanifest", "destination": "/assets/manifest.webmanifest" },
    { "source": "/robots.txt", "destination": "/assets/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/assets/sitemap.xml" },
    { "source": "/og-image.jpg", "destination": "/assets/og-image.jpg" },
    { "source": "/logo.png", "destination": "/assets/logo.png" },
    { "source": "/legal/aviso-legal", "destination": "/legal/aviso-legal.html" },
    { "source": "/legal/privacidad", "destination": "/legal/privacidad.html" },
    { "source": "/legal/cookies", "destination": "/legal/cookies.html" },
    { "source": "/legal/terminos", "destination": "/legal/terminos.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(self), camera=(), microphone=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
