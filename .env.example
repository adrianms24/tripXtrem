# Neon Postgres (create at https://console.neon.tech/)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Resend (create at https://resend.com/)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hola@tripxtrem.com

# Email para notificaciones de nuevos partners (opcional, default: partners@tripxtrem.com)
PARTNERS_NOTIFY_EMAIL=adrianmirelessainz@gmail.com

# Salt para hashing IPs (genera con: openssl rand -hex 16)
IP_SALT=cambia-esto-por-32-chars-random

# Rate limit waitlist
WAITLIST_RATE_LIMIT_PER_HOUR=5

# Google Maps (frontend - referrer-restricted)
GOOGLE_MAPS_API_KEY_FRONTEND=AIzaSy...

# Google Maps (backend - sin restricciones)
GOOGLE_MAPS_API_KEY_BACKEND=AIzaSy...

# Admin token (genera con: openssl rand -base64 32)
# Mínimo 16 caracteres. NO LO COMPARTAS.
ADMIN_TOKEN=cambia-esto-por-token-largo-y-random
